{
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "skipLibCheck": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "prisma.config.ts"]
}
